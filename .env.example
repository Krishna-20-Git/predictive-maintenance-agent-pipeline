# ── Local Postgres (docker-compose) ───────────────────────────────────
POSTGRES_DB=mlops_pipeline
POSTGRES_USER=mlops
POSTGRES_PASSWORD=changeme_local_dev
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── FastAPI inference service ─────────────────────────────────────────
INFERENCE_HOST=inference
INFERENCE_PORT=8000

# ── Ollama (local LLM) ─────────────────────────────────────────────────
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_MODEL=mistral

# ── Langfuse (prompt versioning + tracing) — added Week 3 ────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Pipeline tuning ────────────────────────────────────────────────────
GENERATOR_RATE_PER_SEC=2
ALERT_PROBABILITY_THRESHOLD=0.3
AGENT_TRIGGER_THRESHOLD=0.8
